        {
            "name": "1. Admin Actions (Full Access)",
            "item": [
                {
                    "name": "Create Patient Profile (As Admin)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"fullName\": \"Patient Postman\",\n    \"email\": \"patient.postman@mail.com\",\n    \"phone\": \"000555666\",\n    \"birthDate\": \"1990-01-01\",\n    \"gender\": \"M\",\n    \"address\": \"123 Tested Way\"\n}"
                        },
                        "url": "http://localhost:8080/api/patients"
                    },
                    "response": []
                },
                {
                    "name": "Create Doctor (As Admin)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"fullName\": \"Doctor Postman\",\n    \"email\": \"doctor.postman@mail.com\",\n    \"phone\": \"000333444\",\n    \"specialty\": \"Testing\",\n    \"office\": \"Lab 1\",\n    \"biography\": \"Test Doctor\"\n}"
                        },
                        "url": "http://localhost:8080/api/doctors"
                    },
                    "response": []
                }
            ]
        },
