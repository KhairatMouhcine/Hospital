{
    "info": {
        "_postman_id": "mediconnect-rbac-collection-id",
        "name": "Mediconnect RBAC Scenarios",
        "description": "Collection avancée pour tester les droits d'accès (RBAC) via le Gateway (8080).\n\nStructure :\n1. **0. Setup (Tokens)** : Crée les utilisateurs et récupère les tokens pour Admin, Doctor, Patient.\n2. **1. Admin Actions** : Tests des actions autorisées pour l'Admin (tout).\n3. **2. Doctor Actions** : Tests des restrictions Docteur.\n4. **3. Patient Actions** : Tests des restrictions Patient.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "0. Setup (Tokens)",
            "item": [
                {
                    "name": "Register Admin",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"fullName\": \"Admin User\",\n    \"email\": \"admin.postman@mail.com\",\n    \"password\": \"password123\",\n    \"phone\": \"000111222\",\n    \"role\": \"ADMIN\"\n}"
                        },
                        "url": "http://localhost:8080/auth/register"
                    },
                    "response": []
                },
                {
                    "name": "Login Admin & Save Token",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "pm.collectionVariables.set(\"admin_token\", jsonData.token);",
                                    "console.log(\"Admin Token set\");"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
