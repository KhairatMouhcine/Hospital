                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if(jsonData.token) pm.collectionVariables.set(\"admin_token\", jsonData.token);"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
